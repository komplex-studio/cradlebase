# --- Supabase ---
# Find these in your Supabase project: Settings -> API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Publishable key (safe in the browser, respects RLS). Replaces the legacy anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
# Secret key is SECRET. Server-side only, bypasses RLS. Never expose to the browser.
# Replaces the legacy service_role key.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# --- Admin login (simple credentials) ---
ADMIN_EMAIL=admin@example.com
# Generate the hash with: npm run hash -- "yourPassword"  (see scripts/hash-password.js)
ADMIN_PASSWORD_HASH=$2a$10$replace_this_with_a_real_bcrypt_hash

# --- Auth session ---
# Long random string used to sign JWT session cookies. Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=replace_with_a_long_random_secret

# --- SEO ---
# Public base URL of your site. Used for canonical URLs, sitemap, OG tags.
# In production set this to your real domain, e.g. https://www.yourblog.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google AdSense (optional) ---
# Your AdSense publisher ID, e.g. ca-pub-1234567890123456
# Leave blank to disable ads entirely (no scripts/slots render).
NEXT_PUBLIC_ADSENSE_CLIENT=
# Ad slot IDs from your AdSense dashboard (Ads -> By ad unit). Leave blank to hide a slot.
NEXT_PUBLIC_ADSENSE_SLOT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_INFEED=
